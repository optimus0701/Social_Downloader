# Cấu hình API Backend
API_PORT=8000
DOWNLOAD_DIR=/downloads
MAX_FILE_SIZE_MB=2048
CLEANUP_HOURS=24
ALLOWED_DOMAINS=*

# Cấu hình Cookies (Optional) - Đường dẫn tới file cookies.txt
# COOKIES_PATH=/app/cookies.txt

# Cấu hình IPv6 Routing (Cho Oracle Cloud hoặc mạng hỗ trợ IPv6 subnet)
# Dạng block CIDR, hỗ trợ nhiều block cách nhau bằng dấu phẩy
# Ví dụ: 2001:db8:1::/64,2001:db8:2::/64
# IPV6_BLOCKS=

# Số mạng IPv6 /64 để chia ngẫu nhiên nếu provider ko hỗ trợ (vd: 1 nếu chỉ có 1 IPv6 subnet /64)
# IPV6_ENABLED=false
